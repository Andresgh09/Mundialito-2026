# Mundialito — variables de entorno
# Copiá este archivo a .env.local y completá los valores de tu proyecto Supabase.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Secreto para firmar la sesión (>=16 chars). Generá uno propio.
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Código que tus amigos necesitan para registrarse
JOIN_CODE=MUNDIAL2026
